{
    "Version":  "2012-10-17",
    "Statement":  [
                      {
                          "Effect":  "Allow",
                          "Sid":  "AllowAppRoleReadAccess",
                          "Principal":  {
                                            "AWS":  "arn:aws:iam::000000000000:role/lecafe-app-role"
                                        },
                          "Resource":  [
                                           "arn:aws:s3:::lecafe-assets",
                                           "arn:aws:s3:::lecafe-assets/*"
                                       ],
                          "Action":  [
                                         "s3:GetObject",
                                         "s3:ListBucket"
                                     ]
                      },
                      {
                          "Effect":  "Deny",
                          "Sid":  "DenyAllOtherPrincipals",
                          "Principal":  "*",
                          "Condition":  {
                                            "ArnNotEquals":  {
                                                                 "aws:PrincipalArn":  "arn:aws:iam::000000000000:role/lecafe-app-role"
                                                             }
                                        },
                          "Action":  "s3:*"
                      }
                  ]
}
